{
  "name": "demo-recorder",
  "version": "0.1.0",
  "description": "Graba vídeos hero/demo deterministas de cualquier web app (Playwright recordVideo + capa de coreografía + ffmpeg).",
  "type": "module",
  "license": "MIT",
  "author": "rnkr69",
  "keywords": [
    "demo",
    "screencast",
    "playwright",
    "ffmpeg",
    "video",
    "hero-video",
    "tts",
    "screen-recording"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rnkr69/video-hero.git"
  },
  "homepage": "https://github.com/rnkr69/video-hero#readme",
  "bugs": {
    "url": "https://github.com/rnkr69/video-hero/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "demo-recorder": "bin/demo-recorder.js"
  },
  "scripts": {
    "mock": "node examples/mock-server.mjs",
    "record": "node scripts/record.mjs",
    "record:yaml": "node src/run.js examples/demo.yml",
    "frames": "node scripts/frames.mjs",
    "test": "node --test \"test/unit/*.test.js\"",
    "test:watch": "node --test --watch \"test/unit/*.test.js\"",
    "test:coverage": "node --test --experimental-test-coverage \"test/unit/*.test.js\"",
    "test:smoke": "node --test \"test/smoke/*.smoke.js\""
  },
  "dependencies": {
    "@andresaya/edge-tts": "^1.8.0",
    "ffmpeg-static": "^5.2.0",
    "playwright": "^1.49.0",
    "yaml": "^2.6.0"
  }
}
